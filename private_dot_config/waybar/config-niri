{
    "layer": "bottom",
    "position": "top",
    "height": 22,

    "modules-left": ["niri/workspaces"], 
    "modules-center": ["niri/window"],
    "modules-right": ["niri/language", "cpu", "memory", "battery", "pulseaudio", "clock", "tray"],

    "niri/workspaces": {
        "format": "{value}",
        "disable-scroll": false
    },
    "niri/window": {
        "format": "{title}",
	"icon": true,
        "max-length": 45,
        "tooltip": false,
	"rewrite": {
	    "(.*) - Brave": "$1",
            "(.*) — Mozilla Firefox": "$1",
	    "(.*) - fish": "$1 ",
	    "(.*) - emacs": "$1"
        },
    },
    "clock": {
        "format": "{:%a %d %b %H:%M}",
        "tooltip": false
    },
   "battery": {
       "bat": "BAT0",
       "format": "{icon} {capacity}%",
       "format-icons": ["", "", "", "", ""],
       "format-charging": " {capacity}%",
       "interval": 30,
       "states": {
           "warning": 25,
           "critical": 10
       }
    },
    "network": {
    // "interface": "wlp2s0", // (Optional) To force the use of this interface
    "format-wifi": " {essid} ({signalStrength}%)",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} ",
    "format-disconnected": "Disconnected ⚠"
    },
    "pulseaudio": {
        "format": "{icon} {volume}",
        "format-alt": "{icon}",
        "format-alt-click": "click-right",
        "format-muted": "",
        "format-icons": {
            "phone": [" ", " ", " ", " "],
            "default": [""]
        },
        "scroll-step": 10,
        "on-click": "pavucontrol",
        "tooltip": false
    },
    "cpu": {
    "format": " {usage}%",
    "tooltip": false
    },
    "memory": {
        "format": " {}%"
    },
    "niri/language": {
    "format": "{} \udb80\udf0c",
    "format-en": "us",
    "format-gr": "gr",
    "keyboard-name": "at-translated-set-2-keyboard",
    },		
    "custom/test": {
        "format": "{}",
        "exec": "/tmp/test blub",
        "param": "blah",
        "interval": 5
    },
    "tray": {
        "icon-size": 18
    }
}
